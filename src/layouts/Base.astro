---
import '../styles/global.css';
interface Props { title?: string; description?: string; }
const {
  title = 'NexoCotiza — Crea cotizaciones profesionales gratis',
  description = 'Crea cotizaciones profesionales y descárgalas en PDF o Word. Gratis, sin registro. Un producto de Nexo Software.',
} = Astro.props;

// URL canónica/absolutas a partir de `site` (astro.config). Si no hay site, cae a la ruta.
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const ogImage = Astro.site ? new URL('/og-image.png', Astro.site).href : '/og-image.png';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Favicons / íconos (todos derivados de /nexocotiza.png) -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0E7BD6" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="NexoCotiza" />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Vercel Web Analytics: visitas + eventos personalizados, sin cookies.
         El stub recibe eventos siempre; el script real se carga solo en
         producción (en dev daría 404). Requiere "Web Analytics" habilitado en
         el panel de Vercel del proyecto. -->
    <script is:inline>
      window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
    </script>
    {import.meta.env.PROD && <script is:inline defer src="/_vercel/insights/script.js"></script>}
  </head>
  <body>
    <slot />

    <script>
      // Captura el evento de instalación lo antes posible (puede dispararse
      // antes de que React monte) y lo expone para el botón "Instalar app".
      window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        (window as any).__deferredInstallPrompt = e;
        window.dispatchEvent(new Event('pwa-installable'));
      });
      window.addEventListener('appinstalled', () => {
        (window as any).__deferredInstallPrompt = null;
        window.dispatchEvent(new Event('pwa-installed'));
        if (typeof (window as any).va === 'function') (window as any).va('event', { name: 'app_instalada' });
      });

      // Registra el service worker (solo en producción para no interferir con HMR).
      if (import.meta.env.PROD && 'serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>
  </body>
</html>
