---
import Base from '../layouts/Base.astro';
import App from '../components/App.tsx';
---

<Base>
  <!-- Encabezado -->
  <header class="border-b border-line bg-white/70">
    <div class="mx-auto flex max-w-[1280px] flex-wrap items-center justify-between gap-3 px-4 py-4">
      <a href="/" class="flex items-center gap-2.5">
        <img src="/nexocotiza.png" alt="NexoCotiza" width="36" height="36" class="h-9 w-9" />
        <span class="font-sora text-xl font-bold tracking-tight text-ink">NexoCotiza</span>
      </a>
      <div class="flex items-center gap-3">
        <span class="hidden rounded-full border border-line px-3 py-1 text-[12px] font-semibold text-gray sm:inline">
          Gratis · sin registro
        </span>
        <a
          href="https://www.nexosoftware.cl"
          target="_blank"
          rel="noopener"
          class="text-[12px] font-semibold text-gray transition hover:text-blue"
        >
          Un producto de Nexo Software
        </a>
      </div>
    </div>
  </header>

  <!-- Intro breve -->
  <section class="mx-auto max-w-[1280px] px-4 pt-8 pb-2">
    <h1 class="font-sora text-2xl font-bold tracking-tight text-ink sm:text-3xl">
      Crea cotizaciones profesionales en minutos
    </h1>
    <p class="mt-2 max-w-2xl text-[15px] text-gray">
      Completa los datos, sube tu logo y descarga en <b class="text-ink">PDF</b> o
      <b class="text-ink">Word</b>. Tus datos quedan en tu navegador: no necesitas crear cuenta.
    </p>

    <!-- Beneficios / confianza -->
    <ul class="mt-5 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <li class="flex items-center gap-3 rounded-xl border border-line bg-white px-4 py-3 shadow-sm">
        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-blue/10 text-blue">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/>
            <circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/>
          </svg>
        </span>
        <span>
          <span class="block text-[13px] font-semibold text-ink">100% gratis</span>
          <span class="block text-[12px] text-gray">Sin límites ni marcas de agua.</span>
        </span>
      </li>
      <li class="flex items-center gap-3 rounded-xl border border-line bg-white px-4 py-3 shadow-sm">
        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-blue/10 text-blue">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
        </span>
        <span>
          <span class="block text-[13px] font-semibold text-ink">Privado · sin registro</span>
          <span class="block text-[12px] text-gray">Tus datos no salen del navegador.</span>
        </span>
      </li>
      <li class="flex items-center gap-3 rounded-xl border border-line bg-white px-4 py-3 shadow-sm">
        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-blue/10 text-blue">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"/>
            <path d="M14 2v4a2 2 0 0 0 2 2h4"/>
            <path d="M12 18v-6"/>
            <path d="m9 15 3 3 3-3"/>
          </svg>
        </span>
        <span>
          <span class="block text-[13px] font-semibold text-ink">PDF y Word</span>
          <span class="block text-[12px] text-gray">Descarga lista para enviar.</span>
        </span>
      </li>
    </ul>
  </section>

  <!-- Editor (corre 100% en el navegador) -->
  <main class="pt-4">
    <!--
      Skeleton estático: se pinta al instante (sin JS) para evitar el vacío
      mientras descarga/ejecuta el bundle de React. QuoteEditor lo elimina al montar.
    -->
    <div id="boot-skeleton" class="mx-auto max-w-[1280px] px-4 pb-16">
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(0,500px)]">
        <div class="flex flex-col gap-5">
          <div class="h-44 animate-pulse rounded-xl border border-line bg-white/60 shadow-sm"></div>
          <div class="h-44 animate-pulse rounded-xl border border-line bg-white/60 shadow-sm"></div>
          <div class="h-44 animate-pulse rounded-xl border border-line bg-white/60 shadow-sm"></div>
          <div class="h-44 animate-pulse rounded-xl border border-line bg-white/60 shadow-sm"></div>
        </div>
        <div class="hidden lg:block">
          <div class="sticky top-[68px] h-[calc(100vh-84px)] animate-pulse rounded-xl border border-line bg-white/60 shadow-sm"></div>
        </div>
      </div>
    </div>
    <App client:only="react" />
  </main>

  <!-- Footer -->
  <footer class="border-t border-line bg-white/60">
    <div class="mx-auto flex max-w-[1280px] flex-col items-center justify-between gap-2 px-4 py-6 text-center text-[12px] text-gray sm:flex-row sm:text-left">
      <span>
        <b class="text-ink">NexoCotiza</b> — una cotización no es un documento tributario.
      </span>
      <span>
        ¿Necesitas software a medida?
        <a href="https://www.nexosoftware.cl" target="_blank" rel="noopener" class="font-semibold text-blue hover:text-blue-deep">
          Conversemos con Nexo Software →
        </a>
      </span>
    </div>
  </footer>
</Base>
