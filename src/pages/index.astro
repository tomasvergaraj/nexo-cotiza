---
import Base from '../layouts/Base.astro';
import App from '../components/App.tsx';

const year = new Date().getFullYear();
---

<Base>
  <!-- Encabezado -->
  <header class="border-b border-line bg-white/70">
    <div class="mx-auto flex max-w-[1280px] flex-wrap items-center justify-between gap-3 px-4 py-4">
      <a href="/" class="flex items-center gap-2.5">
        <img src="/nexocotiza.png" alt="NexoCotiza" width="36" height="36" class="h-9 w-9" />
        <span class="font-sora text-xl font-bold tracking-tight text-ink">NexoCotiza</span>
      </a>
      <div class="flex items-center gap-3">
        <span class="hidden rounded-full border border-line px-3 py-1 text-[12px] font-semibold text-gray sm:inline">
          Gratis · sin registro
        </span>
        <a
          href="https://www.nexosoftware.cl"
          target="_blank"
          rel="noopener"
          class="text-[12px] font-semibold text-gray transition hover:text-blue"
        >
          Un producto de Nexo Software
        </a>
      </div>
    </div>
  </header>

  <!-- Intro breve -->
  <section class="mx-auto max-w-[1280px] px-4 pt-8 pb-2">
    <h1 class="max-w-3xl text-balance font-sora text-3xl font-bold tracking-tight text-ink sm:text-4xl">
      Crea cotizaciones profesionales en minutos
    </h1>
    <p class="mt-2 max-w-2xl text-[15px] text-muted">
      Completa los datos, sube tu logo y descarga en <b class="text-ink">PDF</b> o
      <b class="text-ink">Word</b>. Tus datos quedan en tu navegador: no necesitas crear cuenta.
    </p>

    <!-- Beneficios / confianza -->
    <ul class="mt-5 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <li class="flex items-center gap-3 rounded-xl border border-line bg-white px-4 py-3 shadow-sm">
        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-blue/10 text-blue">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/>
            <circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/>
          </svg>
        </span>
        <span>
          <span class="block text-[13px] font-semibold text-ink">100% gratis</span>
          <span class="block text-[12px] text-gray">Sin límites ni marcas de agua.</span>
        </span>
      </li>
      <li class="flex items-center gap-3 rounded-xl border border-line bg-white px-4 py-3 shadow-sm">
        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-blue/10 text-blue">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
        </span>
        <span>
          <span class="block text-[13px] font-semibold text-ink">Privado · sin registro</span>
          <span class="block text-[12px] text-gray">Tus datos no salen del navegador.</span>
        </span>
      </li>
      <li class="flex items-center gap-3 rounded-xl border border-line bg-white px-4 py-3 shadow-sm">
        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-blue/10 text-blue">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"/>
            <path d="M14 2v4a2 2 0 0 0 2 2h4"/>
            <path d="M12 18v-6"/>
            <path d="m9 15 3 3 3-3"/>
          </svg>
        </span>
        <span>
          <span class="block text-[13px] font-semibold text-ink">PDF y Word</span>
          <span class="block text-[12px] text-gray">Descarga lista para enviar.</span>
        </span>
      </li>
    </ul>
  </section>

  <!-- Editor (corre 100% en el navegador) -->
  <main class="pt-4">
    <!--
      Skeleton estático: se pinta al instante (sin JS) para evitar el vacío
      mientras descarga/ejecuta el bundle de React. QuoteEditor lo elimina al montar.
    -->
    <div id="boot-skeleton" class="mx-auto max-w-[1280px] px-4 pb-16">
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(0,500px)]">
        <div class="flex flex-col gap-5">
          <div class="h-44 animate-pulse rounded-xl border border-line bg-white/60 shadow-sm"></div>
          <div class="h-44 animate-pulse rounded-xl border border-line bg-white/60 shadow-sm"></div>
          <div class="h-44 animate-pulse rounded-xl border border-line bg-white/60 shadow-sm"></div>
          <div class="h-44 animate-pulse rounded-xl border border-line bg-white/60 shadow-sm"></div>
        </div>
        <div class="hidden lg:block">
          <div class="sticky top-[68px] h-[calc(100vh-84px)] animate-pulse rounded-xl border border-line bg-white/60 shadow-sm"></div>
        </div>
      </div>
    </div>
    <App client:only="react" />
  </main>

  <!-- Footer -->
  <footer class="border-t border-line bg-white/60">
    <div class="mx-auto max-w-[1280px] px-4 py-10">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Marca + redes -->
        <div class="lg:col-span-2">
          <a href="https://www.nexosoftware.cl" target="_blank" rel="noopener" class="flex items-center gap-2.5">
            <img src="/nexocotiza.png" alt="NexoCotiza" width="32" height="32" class="h-8 w-8" />
            <span class="font-sora text-lg font-bold tracking-tight text-ink">NexoCotiza</span>
          </a>
          <p class="mt-3 max-w-sm text-[13px] leading-relaxed text-gray">
            Crea cotizaciones profesionales gratis y descárgalas en PDF o Word.
            Un producto de <b class="text-ink">Nexo Software SpA</b>, desarrollo de software a medida.
          </p>
          <div class="mt-4 flex items-center gap-2.5">
            <a
              href="https://www.instagram.com/nexosoftwarespa/"
              target="_blank"
              rel="noopener"
              aria-label="Instagram de Nexo Software"
              class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-gray transition hover:border-blue hover:text-blue"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" class="h-[18px] w-[18px]" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
              </svg>
            </a>
            <a
              href="https://www.linkedin.com/company/nexo-software-spa/"
              target="_blank"
              rel="noopener"
              aria-label="LinkedIn de Nexo Software"
              class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-gray transition hover:border-blue hover:text-blue"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" class="h-[18px] w-[18px]" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
            </a>
            <a
              href="https://www.facebook.com/profile.php?id=61588891926236"
              target="_blank"
              rel="noopener"
              aria-label="Facebook de Nexo Software"
              class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-gray transition hover:border-blue hover:text-blue"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" class="h-[18px] w-[18px]" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
              </svg>
            </a>
            <a
              href="https://wa.me/56981964119"
              target="_blank"
              rel="noopener"
              aria-label="WhatsApp de Nexo Software"
              class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-gray transition hover:border-blue hover:text-blue"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" class="h-[18px] w-[18px]" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Contacto -->
        <div>
          <h3 class="font-sora text-[12px] font-semibold uppercase tracking-wide text-ink">Contacto</h3>
          <ul class="mt-3 space-y-2 text-[13px] text-gray">
            <li>
              <a href="mailto:contacto@nexosoftware.cl" class="transition hover:text-blue">contacto@nexosoftware.cl</a>
            </li>
            <li>
              <a href="https://wa.me/56981964119" target="_blank" rel="noopener" class="transition hover:text-blue">+56 9 8196 4119</a>
            </li>
            <li>
              <a href="https://www.nexosoftware.cl" target="_blank" rel="noopener" class="transition hover:text-blue">www.nexosoftware.cl</a>
            </li>
            <li>Quillota, Chile</li>
          </ul>
        </div>

        <!-- Empresa -->
        <div>
          <h3 class="font-sora text-[12px] font-semibold uppercase tracking-wide text-ink">Nexo Software</h3>
          <ul class="mt-3 space-y-2 text-[13px] text-gray">
            <li>Desarrollo de software a medida</li>
            <li>Aplicaciones web y móviles</li>
            <li>
              <a href="https://www.nexosoftware.cl" target="_blank" rel="noopener" class="font-semibold text-blue transition hover:text-blue-deep">
                Conversemos sobre tu proyecto →
              </a>
            </li>
          </ul>
        </div>
      </div>

      <!-- Barra inferior -->
      <div class="mt-8 flex flex-col items-center justify-between gap-2 border-t border-line pt-6 text-center text-[12px] text-gray sm:flex-row sm:text-left">
        <span>© {year} Nexo Software SpA. Todos los derechos reservados.</span>
        <span>NexoCotiza — una cotización no es un documento tributario.</span>
      </div>
    </div>
  </footer>
</Base>
